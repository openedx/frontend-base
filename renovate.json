{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "patch": {
    "automerge": false
  },
  "rebaseStalePrs": true,
  "ignorePaths": ["test-site/**"],
  "packageRules": [
    {
      "packagePatterns": [
        "eslint"
      ],
      "groupName": "eslint"
    },
    {
      "matchPackagePatterns": ["@edx", "@openedx"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": false
    },
    {
      "matchDepTypes": ["peerDependencies"],
      "rangeStrategy": "update-lockfile"
    }
  ]
}
